# Auto detect text files and normalize line endings to LF
* text=auto

# Markdown & Documentation
*.md text eol=lf
*.markdown text eol=lf
*.txt text eol=lf

# JSON & Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Repository Assets (Gizli tutulan ikili varlıklar için kural şablonu)
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.svg binary

# Dağıtım paketleri ve dışarıda bırakılacak IDE konfigürasyonları
.vscode/ export-ignore
.idea/ export-ignore
